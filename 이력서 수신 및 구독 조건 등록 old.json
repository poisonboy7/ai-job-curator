              "sampleData": {},
              "sourceCode": {
                "code": "exports.code = async (inputs) => {\n    let rawText = inputs.dify_response;\n    \n    // 1. DeepSeek의 <think>...</think> 추론 영역 강제 제거\n    rawText = rawText.replace(/<think>[\\s\\S]*?<\\/think>/g, \"\").trim();\n    \n    // 2. 마크다운 ```json 코드 블록 정제\n    rawText = rawText.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n    \n    try {\n        const parsed = JSON.parse(rawText);\n        const job = parsed.primary_job || \"개발자\";\n        let jobsArray = [];\n        if (Array.isArray(job)) {\n            jobsArray = job;\n        } else if (typeof job === 'string') {\n            jobsArray = job.split(',').map(s => s.trim()).filter(Boolean);\n        }\n        if (jobsArray.length === 0) {\n            jobsArray = [\"개발자\"];\n        }\n        \n        return {\n            primary_job: jobsArray[0],\n            primary_jobs: jobsArray,\n            core_skills: parsed.core_skills || [],\n            ai_keywords: parsed.ai_keywords || []\n        };\n    } catch (e) {\n        return {\n            primary_job: \"개발자\",\n            primary_jobs: [\"개발자\"],\n            core_skills: [],\n            ai_keywords: [\"AI\"]\n        };\n    }\n};",
                "packageJson": "{}"
